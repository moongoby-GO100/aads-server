[Unit]
Description=Appium Server for AADS Mobile QA
After=network.target docker.service

[Service]
Type=simple
ExecStart=/root/aads/node_modules_global/bin/appium --address 0.0.0.0 --port 4723 --relaxed-security
Restart=always
Environment=ANDROID_HOME=/opt/android
Environment=JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
Environment=APPIUM_HOME=/root/aads/node_modules_global/lib/node_modules/appium

[Install]
WantedBy=multi-user.target
