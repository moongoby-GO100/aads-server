"""
AADS-186B: CTO 모드
CEO와 기술 전략 토론 · 코드 분석 · 지시서 자동 생성 · 작업 검증 · 영향 분석 · 기술 부채 추적
"""
from __future__ import annotations

import logging
import os
import re
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, List, Optional
from zoneinfo import ZoneInfo

import asyncpg

from app.core.anthropic_client import call_llm_with_fallback
from app.models.ckp import (
    DirectiveResult,
    ImpactReport,
    TechDebtItem,
    TechDebtReport,
    VerificationResult,
)

logger = logging.getLogger(__name__)

AADS_ROOT = Path("/root/aads")
CKP_DIR = AADS_ROOT / ".claude"

AADS_SERVER_URL = os.getenv("AADS_SERVER_URL", "http://localhost:8000")

_TECH_DEBT_TAGS = {"TODO", "FIXME", "HACK", "XXX", "DEPRECATED"}
_SCAN_EXTENSIONS = {".py", ".ts", ".tsx", ".js"}
_SKIP_DIRS = {"node_modules", "__pycache__", ".git", ".next", "dist", "build"}


def _db_url() -> str:
    url = os.getenv("DATABASE_URL", "")
    return url.replace("postgresql://", "postgres://") if url else url


async def _get_conn() -> asyncpg.Connection:
    return await asyncpg.connect(_db_url(), timeout=10)


class CTOMode:
    """CTO 수준 기술 분석·전략 토론·자동 지시서 생성."""

    # ── 1. 전략 토론 (Opus) ────────────────────────────────────────────────

    async def strategy_discussion(self, query: str, ckp_context: str = "") -> str:
        """CEO와 기술 전략 토론 — Claude Opus 사용."""
        system_prompt = (
            "당신은 AADS 시스템의 CTO 역할로 CEO moongoby에게 기술 전략 자문을 제공합니다.\n"
            "응답 구조: 1) 현황 분석 2) 옵션 비교 3) 추천 방향 4) 리스크 5) 다음 단계\n"
            "핵심만, 미사여구 없이, 직접적으로 답변하세요."
        )

        user_content = f"{ckp_context}\n\n## CEO 질문\n{query}"
        result = await call_llm_with_fallback(
            prompt=user_content,
            model="claude-sonnet-4-20250514",
            max_tokens=3000,
            system=system_prompt,
        )
        return result or "LLM 호출 실패"

    # ── 2. 코드 분석 (Sonnet) ──────────────────────────────────────────────

    async def code_analysis(self, project: str, target: str) -> str:
        """코드 흐름 분석 — CKP + Sonnet."""
        # CKP에서 관련 파일 식별
        ckp_info = await self._get_ckp_snippet(project, target)

        system_prompt = (
            "당신은 AADS 코드베이스 전문 분석가입니다.\n"
            "함수 호출 체인, 데이터 흐름, 의존성을 구조화된 보고서로 분석하세요."
        )
        user_content = (
            f"## 분석 대상\n{target}\n\n"
            f"## CKP 컨텍스트\n{ckp_info}\n\n"
            "위 정보를 기반으로 코드 흐름과 의존성을 분석하세요."
        )
        result = await call_llm_with_fallback(
            prompt=user_content,
            model="claude-sonnet-4-20250514",
            max_tokens=2000,
            system=system_prompt,
        )
        return result or "LLM 호출 실패"

    # ── 3. 지시서 자동 생성 + 제출 ───────────────────────────────────────

    async def generate_and_submit_directive(
        self,
        description: str,
        priority: str = "P2",
        size: str = "M",
        dry_run: bool = False,
        **kwargs,
    ) -> DirectiveResult:
        """지시서 자동 생성 + 제출 (dry_run=True 시 파일 저장 없음)."""
        # 다음 task_id 채번
        task_id = await self._next_task_id()

        # CKP에서 관련 파일 조회
        ckp_files = await self._infer_files_owned(description)

        # AI가 ACCEPTANCE_CRITERIA 작성
        criteria = await self._generate_acceptance_criteria(description, task_id)

        content = self._format_directive(
            task_id=task_id,
            description=description,
            priority=priority,
            size=size,
            files_owned=ckp_files,
            criteria=criteria,
        )

        result = DirectiveResult(
            task_id=task_id,
            title=description[:60],
            content=content,
            dry_run=dry_run,
        )

        if dry_run:
            logger.info(f"[CTO] dry_run 지시서: {task_id}")
            return result

        # 실제 제출
        try:
            async with httpx.AsyncClient(timeout=15.0) as client:
                resp = await client.post(
                    f"{AADS_SERVER_URL}/api/v1/directives/submit",
                    json={"task_id": task_id, "content": content},
                )
                if resp.status_code in (200, 201):
                    result.submitted = True
                    logger.info(f"[CTO] 지시서 제출 성공: {task_id}")
                else:
                    result.error = f"submit HTTP {resp.status_code}"
        except Exception as e:
            result.error = str(e)
            logger.error(f"[CTO] 지시서 제출 실패: {e}")

        return result

    # ── 4. 이전 작업 결과 검증 ────────────────────────────────────────────

    async def verify_task(self, task_id: str) -> VerificationResult:
        """이전 작업 결과 소스 레벨 검증."""
        result = VerificationResult(task_id=task_id)

        # STATUS.md에서 커밋 해시 조회
        status_path = AADS_ROOT / "aads-docs" / "STATUS.md"
        if status_path.exists():
            status_text = status_path.read_text()
            sha_match = re.search(r"commit_sha:\s*([a-f0-9]{7,40})", status_text)
            if sha_match:
                result.commit_sha = sha_match.group(1)

        # RESULT 파일에서 완료 정보 조회
        result_dir = Path("/root/.genspark/directives/done")
        for f in result_dir.glob(f"*{task_id}*"):
            content = f.read_text(errors="replace")
            result.checked_files.append(str(f.name))

            # ACCEPTANCE_CRITERIA 항목 체크
            for line in content.splitlines():
                if line.strip().startswith("✅") or "완료" in line or "성공" in line:
                    result.passed.append(line.strip())
                elif line.strip().startswith("❌") or "실패" in line or "누락" in line:
                    result.failed.append(line.strip())

        result.summary = (
            f"task_id={task_id}, commit={result.commit_sha or 'unknown'}, "
            f"passed={len(result.passed)}, failed={len(result.failed)}"
        )
        return result

    # ── 5. 변경 사전 영향 분석 ────────────────────────────────────────────

    async def impact_analysis(self, description: str) -> ImpactReport:
        """변경 사전 영향 분석 — CKP DEPENDENCY-MAP 활용."""
        report = ImpactReport()

        # 대상 파일 식별
        report.target_files = await self._infer_files_owned(description)

        # DEPENDENCY-MAP에서 영향 파일 조회
        dep_map = CKP_DIR / "DEPENDENCY-MAP.md"
        if dep_map.exists():
            dep_text = dep_map.read_text()
            for target in report.target_files:
                fname = Path(target).name
                for line in dep_text.splitlines():
                    if fname in line and "→" in line:
                        parts = line.split("→")
                        if len(parts) >= 2:
                            affected = parts[0].strip().strip("`- ")
                            if affected and affected not in report.affected_files:
                                report.affected_files.append(affected)

        # 영향받는 서비스 식별
        service_keywords = ["chat_service", "intent_router", "context_builder", "ceo_chat", "ops"]
        for f in report.affected_files:
            for kw in service_keywords:
                if kw in f and kw not in report.affected_services:
                    report.affected_services.append(kw)

        # 리스크 레벨 판정
        n = len(report.affected_files)
        if n >= 10 or any("main.py" in f for f in report.affected_files):
            report.risk_level = "HIGH"
        elif n >= 3:
            report.risk_level = "MEDIUM"
        else:
            report.risk_level = "LOW"

        report.summary = (
            f"대상: {len(report.target_files)}개 → 영향: {len(report.affected_files)}개 파일, "
            f"서비스: {', '.join(report.affected_services[:5]) or '없음'}, 리스크: {report.risk_level}"
        )
        return report

    # ── 6. 기술 부채 추적 ──────────────────────────────────────────────────

    async def track_tech_debt(self, project: str) -> TechDebtReport:
        """기술 부채 자동 추적 — TODO/FIXME/HACK/XXX/DEPRECATED 스캔."""
        report = TechDebtReport(project=project)
        root = AADS_ROOT

        by_tag: Dict[str, int] = {tag: 0 for tag in _TECH_DEBT_TAGS}
        by_file: Dict[str, int] = {}

        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = [d for d in dirnames if d not in _SKIP_DIRS and not d.startswith(".")]
            for fname in filenames:
                fpath = Path(dirpath) / fname
                if fpath.suffix not in _SCAN_EXTENSIONS:
                    continue
                try:
                    lines = fpath.read_text(errors="replace").splitlines()
                except Exception:
                    continue

                rel = str(fpath.relative_to(root))
                for i, line in enumerate(lines, 1):
                    for tag in _TECH_DEBT_TAGS:
                        if tag in line:
                            priority = "HIGH" if tag in ("FIXME", "HACK") else "MEDIUM"
                            report.items.append(TechDebtItem(
                                file_path=rel,
                                line_number=i,
                                tag=tag,
                                content=line.strip()[:120],
                                priority=priority,
                            ))
                            by_tag[tag] = by_tag.get(tag, 0) + 1
                            by_file[rel] = by_file.get(rel, 0) + 1

        report.by_tag = {k: v for k, v in by_tag.items() if v > 0}
        report.by_file = dict(sorted(by_file.items(), key=lambda x: x[1], reverse=True)[:20])
        report.total = len(report.items)
        report.summary = (
            f"총 {report.total}건: "
            + ", ".join(f"{k}={v}" for k, v in report.by_tag.items())
        )
        return report

    # ── 내부 헬퍼 ─────────────────────────────────────────────────────────

    async def _next_task_id(self) -> str:
        """마지막 AADS task_id + 1 채번."""
        try:
            conn = await _get_conn()
            try:
                row = await conn.fetchrow(
                    """
                    SELECT task_id FROM directive_lifecycle
                    WHERE project = 'AADS' OR task_id LIKE 'AADS-%'
                    ORDER BY created_at DESC LIMIT 1
                    """
                )
                if row:
                    m = re.search(r"(\d+)$", row["task_id"])
                    if m:
                        return f"AADS-{int(m.group(1)) + 1}"
            finally:
                await conn.close()
        except Exception:
            pass

        # DB 실패 시 현재 시각 기반 ID
        now = datetime.now(ZoneInfo("Asia/Seoul"))
        return f"AADS-{now.strftime('%Y%m%d%H%M')}"

    async def _infer_files_owned(self, description: str) -> List[str]:
        """설명에서 관련 파일 목록 추론 (CKP CODEBASE-MAP 활용)."""
        cmap = CKP_DIR / "CODEBASE-MAP.md"
        if not cmap.exists():
            return []

        text = cmap.read_text()
        keywords = [w for w in description.lower().split() if len(w) > 4]
        files: List[str] = []

        for line in text.splitlines():
            if line.startswith("###") and "`" in line:
                m = re.search(r"`([^`]+\.(py|ts|tsx))`", line)
                if m:
                    fpath = m.group(1)
                    if any(kw in fpath.lower() for kw in keywords):
                        files.append(fpath)

        return files[:10]

    async def _generate_acceptance_criteria(self, description: str, task_id: str) -> str:
        """AI가 ACCEPTANCE_CRITERIA 작성."""
        prompt = (
            f"다음 작업에 대한 ACCEPTANCE_CRITERIA를 구체적으로 작성하세요.\n"
            f"task_id: {task_id}\n"
            f"description: {description}\n\n"
            "형식: 번호 매긴 구체적인 검증 항목 (5~10개), 각 항목은 검증 가능한 수준으로"
        )
        result = await call_llm_with_fallback(
            prompt=prompt,
            model="claude-sonnet-4-20250514",
            max_tokens=800,
        )
        return result or "LLM 호출 실패"

    async def _get_ckp_snippet(self, project: str, target: str) -> str:
        """CKP에서 target 관련 스니펫 조회."""
        cmap = CKP_DIR / "CODEBASE-MAP.md"
        if not cmap.exists():
            return "(CKP 없음)"

        text = cmap.read_text()
        lines = text.splitlines()
        target_lower = target.lower()
        snippet_lines: List[str] = []
        capture = False

        for line in lines:
            if target_lower in line.lower():
                capture = True
            if capture:
                snippet_lines.append(line)
                if len(snippet_lines) > 20:
                    break

        return "\n".join(snippet_lines) if snippet_lines else "(관련 항목 없음)"

    def _format_directive(
        self,
        task_id: str,
        description: str,
        priority: str,
        size: str,
        files_owned: List[str],
        criteria: str,
    ) -> str:
        """D-022 포맷 지시서 문자열 생성."""
        now = datetime.now(ZoneInfo("Asia/Seoul")).strftime("%Y-%m-%d")
        files_str = "\n".join(f"  - {f} (신규/수정)" for f in files_owned) if files_owned else "  - (자동 식별 필요)"

        return f""">>>DIRECTIVE_START
TASK_ID: {task_id}
TITLE: {description[:80]}
PRIORITY: {priority}
SIZE: {size}
MODEL: sonnet
ASSIGNEE: Claude (서버68)
CREATED_AT: {now}

DESCRIPTION:
{description}

FILES_OWNED:
{files_str}

ACCEPTANCE_CRITERIA:
{criteria}

COMPLETION:
  - 모든 ACCEPTANCE_CRITERIA 충족
  - 테스트 통과
  - HANDOVER.md 업데이트
  - Git 커밋
>>>DIRECTIVE_END
"""
